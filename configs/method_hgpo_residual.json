{
  "run": {
    "name": "hgpo_residual_webshop",
    "output_dir": "experiments/manifests",
    "seed": 11
  },
  "train": {
    "algorithm": "hgpo",
    "total_episodes": 200,
    "batch_size": 4,
    "learning_rate": 1e-6,
    "checkpoint_every": 50,
    "eval_every": 25,
    "K_trajectories_per_task": 8,
    "kl_coeff": 0.04,
    "clip_eps": 0.2,
    "grad_accum_steps": 2,
    "max_tokens_per_microbatch": 1024,
    "gpu_mem_util": 0.20
  },
  "policy": {
    "backbone": "Qwen2.5-1.5B-Instruct",
    "lora": true,
    "lora_target_modules": ["q_proj", "k_proj", "v_proj", "o_proj"],
    "lora_rank": 16
  },
  "hgpo": {
    "alpha": 0.5,
    "lambda_consistency": 0.1,
    "decomposer": "residual"
  },
  "turnrd": {
    "mode": 1,
    "layers": 6,
    "hidden_size": 384,
    "n_heads": 4,
    "max_turns": 16,
    "dropout": 0.1,
    "causal": true,
    "value_head": true,
    "cls_token": true,
    "refresh_every_episodes": 50,
    "turnrd_lr": 5e-4,
    "lambda_value": 0.5,
    "gamma": 0.95,
    "lambda_entropy": 0.01,
    "lambda_contrastive": 0.1,
    "contrastive_temperature": 0.1,
    "replay_buffer_path": "/vol/cache/turnrd_replay.jsonl",
    "ckpt_path": "/vol/cache/residual_ckpt.pt",
    "distill_source": null
  },
  "residual": {
    "init_gamma": 1.0
  },
  "logging": {
    "print_every": 10
  },
  "_notes": "H-GRPO Method D: Residual Decomposer. Adds γ_prior · raw_env_reward as additive bias on the α softmax inside TurnRD's [CLS] cross-attention pool. γ_prior is a learnable nn.Parameter (init from residual.init_gamma; AdamW updates at turnrd_lr). γ → 0 reduces to Method B (TurnRD); γ → ∞ collapses to Method C (Progress). turnrd.gamma is the V-head DISCOUNT factor — different concept from residual.init_gamma."
}
