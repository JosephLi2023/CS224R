{
  "run": {
    "name": "hgpo_progress_webshop",
    "output_dir": "experiments/manifests",
    "seed": 11
  },
  "train": {
    "algorithm": "hgpo",
    "total_episodes": 200,
    "batch_size": 4,
    "learning_rate": 1e-6,
    "checkpoint_every": 50,
    "eval_every": 25,
    "K_trajectories_per_task": 4,
    "kl_coeff": 0.04,
    "clip_eps": 0.2,
    "grad_accum_steps": 2
  },
  "policy": {
    "backbone": "Qwen2.5-1.5B-Instruct",
    "lora": true,
    "lora_target_modules": ["q_proj", "k_proj", "v_proj", "o_proj"],
    "lora_rank": 16
  },
  "hgpo": {
    "alpha": 0.5,
    "lambda_consistency": 0.1,
    "decomposer": "progress"
  },
  "logging": {
    "print_every": 10
  },
  "_notes": "H-GRPO Method C: Progress-based decomposer (WebShop product-match-score delta). Zero additional training/inference cost."
}
