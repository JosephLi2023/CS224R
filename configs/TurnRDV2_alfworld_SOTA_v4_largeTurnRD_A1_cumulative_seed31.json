{
  "run": {
    "name": "TurnRDV2_alfworld_SOTA_v4_largeTurnRD_A1",
    "output_dir": "experiments/manifests",
    "seed": 31
  },
  "env": {
    "name": "alfworld",
    "max_steps": 40,
    "observation_mode": "text",
    "task_split": "train",
    "use_textworld_intermediate_reward": true,
    "use_facts_diff_intermediate_reward": true,
    "env_kwargs": {
      "config": {
        "dataset": {
          "data_path": "$ALFWORLD_DATA/json_2.1.1/train",
          "eval_id_data_path": "$ALFWORLD_DATA/json_2.1.1/valid_seen",
          "eval_ood_data_path": "$ALFWORLD_DATA/json_2.1.1/valid_unseen",
          "num_train_games": 400,
          "num_eval_games": 50
        },
        "env": {
          "type": "AlfredTWEnv",
          "regen_game_files": false,
          "domain_randomization": false,
          "task_types": [
            1,
            2,
            3,
            4,
            5,
            6
          ],
          "expert_timeout_steps": 150,
          "expert_type": "handcoded",
          "goal_desc_human_anns_prob": 0.0,
          "hybrid": {
            "start_eps": 100000,
            "thor_prob": 0.5,
            "eval_mode": "tw"
          }
        },
        "general": {
          "random_seed": 42,
          "use_cuda": false,
          "visdom": false,
          "task": "alfred",
          "training_method": "dagger",
          "save_path": "./training/",
          "observation_pool_capacity": 3,
          "hide_init_receptacles": false
        },
        "controller": {
          "type": "oracle",
          "debug": false,
          "load_receps": false
        },
        "logic": {
          "domain": "$ALFWORLD_DATA/logic/alfred.pddl",
          "grammar": "$ALFWORLD_DATA/logic/alfred.twl2"
        },
        "dagger": {
          "training": {
            "max_nb_steps_per_episode": 50
          },
          "fraction_assist": {
            "fraction_assist_anneal_episodes": 0,
            "fraction_assist_anneal_from": 1.0,
            "fraction_assist_anneal_to": 0.01
          },
          "fraction_random": {
            "fraction_random_anneal_episodes": 0,
            "fraction_random_anneal_from": 0.0,
            "fraction_random_anneal_to": 0.0
          },
          "replay": {
            "replay_memory_capacity": 0,
            "replay_memory_priority_fraction": 0.0,
            "update_per_k_game_steps": 1,
            "replay_batch_size": 1,
            "multi_step": 1,
            "replay_sample_history_length": 1,
            "replay_sample_update_from": 1
          }
        }
      }
    }
  },
  "train": {
    "algorithm": "hgpo",
    "total_episodes": 200,
    "batch_size": 4,
    "learning_rate": 5e-06,
    "checkpoint_every": 50,
    "eval_every": 25,
    "K_trajectories_per_task": 8,
    "kl_coeff": 0.04,
    "clip_eps": 0.2,
    "grad_accum_steps": 2,
    "max_tokens_per_microbatch": 1024,
    "gpu_mem_util": 0.4,
    "sync_every": 8
  },
  "policy": {
    "backbone": "Qwen2.5-1.5B-Instruct",
    "lora": true,
    "lora_target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],
    "lora_rank": 32
  },
  "hgpo": {
    "alpha": 0.5,
    "lambda_consistency": 0.0,
    "decomposer": "turnrd",
    "use_v_projection_for_decomposition": true,
    "v_projection_clamp": 2.0
  },
  "turnrd": {
    "version": "v2",
    "mode": 1,
    "layers": 3,
    "hidden_size": 256,
    "n_heads": 4,
    "max_turns": 50,
    "dropout": 0.15,
    "causal": false,
    "progress_prior_strength": 1.0,
    "refresh_every_episodes": 10,
    "turnrd_lr": 0.0002,
    "lambda_value": 1.0,
    "lambda_rank": 0.1,
    "lambda_progress": 0.01,
    "rank_margin": 0.1,
    "recency_decay_half_life": 4.0,
    "legacy_decay_weight": 0.5,
    "min_batch_weight": 0.001,
    "replay_buffer_path": "/vol/cache/TurnRDV2_alfworld_SOTA_v4_largeTurnRD_A1/replay.jsonl",
    "ckpt_path": "/vol/cache/TurnRDV2_alfworld_SOTA_v4_largeTurnRD_A1/ckpt.pt",
    "emit_goal_text": true,
    "emit_goal_emb": true,
    "goal_conditioned_value_head": true,
    "cumulative_train": true,
    "warmup_steps": 100,
    "lr_schedule": "warmup_cosine",
    "fresh_emphasis_window_rounds": 2,
    "fresh_emphasis_n_epochs": 2
  },
  "logging": {
    "print_every": 10
  },
  "_notes": "[v4 A1 plan: turnrd_v2_continual_larger] Larger TurnRD (hidden=256, layers=3, head_dim=64) + cumulative warm-start + LR warmup_cosine + fresh-emphasis pass. Seed=31, K=8 (canonical), 10 rounds. Apples-to-apples vs goalcondFiLM (same train slice [24800, 25600), same eval pool [6500, 6600)). Disjoint cache prefix from goalcondFiLM lineage."
}