{
  "run": {
    "name": "smoke_method_b_v2_alfworld",
    "output_dir": "experiments/manifests",
    "seed": 11
  },
  "env": {
    "name": "alfworld",
    "max_steps": 40,
    "observation_mode": "text",
    "task_split": "train",
    "env_kwargs": {
      "config": {
        "dataset": {
          "data_path": "$ALFWORLD_DATA/json_2.1.1/train",
          "eval_id_data_path": "$ALFWORLD_DATA/json_2.1.1/valid_seen",
          "eval_ood_data_path": "$ALFWORLD_DATA/json_2.1.1/valid_unseen",
          "num_train_games": 50,
          "num_eval_games": 10
        },
        "env": {
          "type": "AlfredTWEnv",
          "regen_game_files": false,
          "domain_randomization": false,
          "task_types": [
            1,
            2,
            3,
            4,
            5,
            6
          ],
          "expert_timeout_steps": 150,
          "expert_type": "handcoded",
          "goal_desc_human_anns_prob": 0.0,
          "hybrid": {
            "start_eps": 100000,
            "thor_prob": 0.5,
            "eval_mode": "tw"
          }
        },
        "general": {
          "random_seed": 42,
          "use_cuda": false,
          "visdom": false,
          "task": "alfred",
          "training_method": "dagger",
          "save_path": "./training/",
          "observation_pool_capacity": 3,
          "hide_init_receptacles": false
        },
        "controller": {
          "type": "oracle",
          "debug": false,
          "load_receps": false
        },
        "logic": {
          "domain": "$ALFWORLD_DATA/logic/alfred.pddl",
          "grammar": "$ALFWORLD_DATA/logic/alfred.twl2"
        }
      }
    }
  },
  "train": {
    "algorithm": "hgpo",
    "total_episodes": 200,
    "batch_size": 4,
    "learning_rate": 1e-06,
    "checkpoint_every": 50,
    "eval_every": 25,
    "K_trajectories_per_task": 4,
    "kl_coeff": 0.04,
    "clip_eps": 0.2,
    "grad_accum_steps": 2,
    "max_tokens_per_microbatch": 1024,
    "gpu_mem_util": 0.2
  },
  "policy": {
    "backbone": "Qwen2.5-1.5B-Instruct",
    "lora": true,
    "lora_target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj"
    ],
    "lora_rank": 16
  },
  "hgpo": {
    "alpha": 0.5,
    "lambda_consistency": 0.0,
    "decomposer": "turnrd"
  },
  "turnrd": {
    "version": "v2",
    "mode": 1,
    "layers": 2,
    "hidden_size": 128,
    "n_heads": 4,
    "max_turns": 16,
    "dropout": 0.1,
    "causal": false,
    "progress_prior_strength": 1.0,
    "refresh_every_episodes": 10,
    "turnrd_lr": 0.0005,
    "lambda_value": 0.0,
    "lambda_rank": 0.1,
    "lambda_progress": 0.01,
    "rank_margin": 0.1,
    "replay_buffer_path": "/vol/cache/smoke_method_b_v2_alfworld/replay.jsonl",
    "ckpt_path": "/vol/cache/smoke_method_b_v2_alfworld/ckpt.pt"
  },
  "logging": {
    "print_every": 10
  },
  "_notes": "SMOKE-only variant of method_hgpo_turnrd_v2_alfworld.json: num_train_games=50, num_eval_games=10 to keep AlfWorld env construction under ~5 min/env (vs ~30 min/env at 200 games). For the actual sweep, use the parent config. Cache redirected to /vol/cache/smoke_*/ so smoke artifacts dont contaminate sweep state."
}