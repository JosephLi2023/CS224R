{
  "run": {
    "name": "method_b_v2_carry_vhead",
    "output_dir": "experiments/manifests",
    "seed": 11
  },
  "train": {
    "algorithm": "hgpo",
    "total_episodes": 200,
    "batch_size": 4,
    "learning_rate": 1e-06,
    "checkpoint_every": 50,
    "eval_every": 25,
    "K_trajectories_per_task": 4,
    "kl_coeff": 0.04,
    "clip_eps": 0.2,
    "grad_accum_steps": 2,
    "max_tokens_per_microbatch": 1024,
    "gpu_mem_util": 0.2
  },
  "policy": {
    "backbone": "Qwen2.5-1.5B-Instruct",
    "lora": true,
    "lora_target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj"
    ],
    "lora_rank": 16
  },
  "hgpo": {
    "alpha": 0.5,
    "lambda_consistency": 0.0001,
    "decomposer": "turnrd"
  },
  "turnrd": {
    "version": "v2",
    "mode": 1,
    "layers": 2,
    "hidden_size": 128,
    "n_heads": 4,
    "max_turns": 16,
    "dropout": 0.1,
    "causal": false,
    "progress_prior_strength": 1.0,
    "refresh_every_episodes": 10,
    "turnrd_lr": 0.0005,
    "lambda_value": 0.0,
    "lambda_rank": 0.1,
    "lambda_progress": 0.01,
    "rank_margin": 0.1,
    "replay_buffer_path": "/vol/cache/method_b_v2_carry_vhead/replay.jsonl",
    "ckpt_path": "/vol/cache/method_b_v2_carry_vhead/ckpt.pt"
  },
  "logging": {
    "print_every": 10
  },
  "_notes": "TurnRDv2 + carry-policy + V-HEAD-AS-PPO-BASELINE enabled. lambda_consistency=0.0001 is the minimum value that unlocks the trainer.py:647 gate so the dead-code v6 path (value_per_turn replacement of per-position-normalized turn_adv) actually fires. The 0.0001 weight on the consistency loss itself is negligible (~1e-4 of total loss); the value of this knob is purely as a feature flag for the V-head replacement."
}