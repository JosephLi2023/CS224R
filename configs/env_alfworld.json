{
  "env": {
    "name": "alfworld",
    "max_steps": 40,
    "observation_mode": "text",
    "task_split": "train",
    "_env_kwargs_doc": "AlfredTWEnv expects a `config` dict (mirroring AlfWorld's example YAML) plus `train_eval` at construction time. The adapter forwards `task_split` as `train_eval` automatically; `config` is the upstream's nested-dict schema. Paths reference $ALFWORLD_DATA which app_alfworld_install.py sets to /vol/data/alfworld/ on the Modal volume. `batch_size: 1` because RolloutCollector drives K parallel adapter instances itself \u2014 each adapter wraps a single-game env. `expert_type: planner` matches the alfred_tw default. `goal_desc_human_anns_prob: 0.0` uses the templated goal strings (deterministic; the human-annotation pool is small and varies).",
    "env_kwargs": {
      "config": {
        "dataset": {
          "data_path": "$ALFWORLD_DATA/json_2.1.1/train",
          "eval_id_data_path": "$ALFWORLD_DATA/json_2.1.1/valid_seen",
          "eval_ood_data_path": "$ALFWORLD_DATA/json_2.1.1/valid_unseen",
          "num_train_games": 200,
          "num_eval_games": 50
        },
        "env": {
          "type": "AlfredTWEnv",
          "regen_game_files": false,
          "domain_randomization": false,
          "task_types": [
            1,
            2,
            3,
            4,
            5,
            6
          ],
          "expert_timeout_steps": 150,
          "expert_type": "handcoded",
          "goal_desc_human_anns_prob": 0.0,
          "hybrid": {
            "start_eps": 100000,
            "thor_prob": 0.5,
            "eval_mode": "tw"
          }
        },
        "general": {
          "random_seed": 42,
          "use_cuda": false,
          "visdom": false,
          "task": "alfred",
          "training_method": "dagger",
          "save_path": "./training/",
          "observation_pool_capacity": 3,
          "hide_init_receptacles": false
        },
        "controller": {
          "type": "oracle",
          "debug": false,
          "load_receps": false
        },
        "logic": {
          "domain": "$ALFWORLD_DATA/logic/alfred.pddl",
          "grammar": "$ALFWORLD_DATA/logic/alfred.twl2"
        },
        "dagger": {
          "training": {
            "max_nb_steps_per_episode": 50
          },
          "fraction_assist": {
            "fraction_assist_anneal_episodes": 0,
            "fraction_assist_anneal_from": 1.0,
            "fraction_assist_anneal_to": 0.01
          },
          "fraction_random": {
            "fraction_random_anneal_episodes": 0,
            "fraction_random_anneal_from": 0.0,
            "fraction_random_anneal_to": 0.0
          },
          "replay": {
            "replay_memory_capacity": 0,
            "replay_memory_priority_fraction": 0.0,
            "update_per_k_game_steps": 1,
            "replay_batch_size": 1,
            "multi_step": 1,
            "replay_sample_history_length": 1,
            "replay_sample_update_from": 1
          }
        }
      }
    }
  }
}