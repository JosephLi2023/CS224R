{
  "run": {
    "name": "max_grpo_signed_attention_a0p5_lr2em06_kl0p05_k4_t30_grid_milestone_v8",
    "output_dir": "experiments/manifests",
    "seed": 42
  },
  "env": {
    "name": "alfworld",
    "max_steps": 30,
