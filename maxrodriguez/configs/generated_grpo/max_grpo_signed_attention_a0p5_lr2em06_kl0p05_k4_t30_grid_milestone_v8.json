  },
  "sft": {
    "adapter": "/vol/checkpoints/maxrodriguez_milestone/final_sft/sftfinal_milestone_v8_e3_lr2E-05_seq1024_ga4_nodagger"
  },
  "dataset_size_mode": "grid",
  "logging": {
    "print_every": 10
  },
  "_notes": "Generated by build_config_for_run. Proposal math: A_H = alpha * A_turn + (1 - alpha) * A_traj."
}
